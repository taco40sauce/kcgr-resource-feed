# Copy this file to ~/.kcgr_secrets/credentials.env (OUTSIDE this repo)
# and fill in your own Graywolf web UI login below.
#
# Do NOT fill this file in and commit it - it's a template only.
# Your real credentials.env lives outside the git repo entirely, so it
# can never accidentally be pushed to GitHub.

GRAYWOLF_USER=Place your login here
GRAYWOLF_PASS=Enter your password here
